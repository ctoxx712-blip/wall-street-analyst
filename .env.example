# Copy this file to .env and fill in your own values.
# .env is git-ignored and must never be committed.

# Required - get one at https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional but strongly recommended for the website.
# Without it, anyone with the URL can use the site and bill your account.
ACCESS_PASSWORD=choose-a-password

# Only needed for the Telegram bot (finance_bot.py)
BOT_TOKEN=123456789:your-telegram-bot-token
CHAT_ID=your-numeric-chat-id
